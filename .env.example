# Cheese Stick Dock — 치지직 오픈 API 계정 연동용 환경변수 템플릿입니다.
# 파일 이름을 '.env.example' 에서 '.env' 로 변경하여 사용하세요.

CHZZK_CLIENT_ID=""
CHZZK_CLIENT_SECRET=""

# CORS 허용 오리진 설정 (예: https://your-app.pages.dev)
# 미설정 시 요청 URL의 origin을 자동으로 사용합니다.
ALLOWED_ORIGIN=""

# Cloudflare KV 캐시 설정 (프로덕션):
# 1. Cloudflare 대시보드 → Workers & Pages → KV → namespace 생성
# 2. Pages 프로젝트 → Settings → Functions → KV namespace bindings
# 3. Variable name: LIVE_STATUS_CACHE, KV namespace: 생성한 namespace 선택

# 로컬 테스트 명령어:
# npm install -g wrangler
# wrangler pages dev . --kv LIVE_STATUS_CACHE
